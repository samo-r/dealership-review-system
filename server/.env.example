# Django gateway (server/) — copy to .env and replace placeholders
# Never commit .env to version control.

# Required
DJANGO_SECRET_KEY=your_django_secret_key_here
backend_url=http://127.0.0.1:3030
sentiment_analyzer_url=http://127.0.0.1:5000

# Optional — JWT (defaults shown)
DJANGO_JWT_SECRET_KEY=your_jwt_signing_secret_here
DJANGO_JWT_ALGORITHM=HS256
DJANGO_JWT_ACCESS_TTL_MINUTES=30
DJANGO_JWT_REFRESH_TTL_DAYS=7

# Environment / security
DJANGO_DEBUG=true
DJANGO_ENV=local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# When the React build is served by this Django service (Railway Option A),
# set both to your Railway public URL, e.g. https://your-app.up.railway.app
# Local SQLite (used when DATABASE_URL is unset)
DJANGO_DB_FILENAME=db.sqlite3

# Railway PostgreSQL — set automatically when you link a Postgres service
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# DATABASE_SSLMODE=require

# Bootstrap admin on deploy (optional; no-op when unset)
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=change_me
# DJANGO_SUPERUSER_EMAIL=admin@example.com

DJANGO_UPSTREAM_TIMEOUT=10

# Async sentiment queue (Upstash: use rediss:// TLS URL)
REDIS_URL=rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379/0
SENTIMENT_QUEUE_NAME=review_sentiment_queue

# Shared with Node API for internal chassis verification
INTERNAL_API_KEY=your_shared_internal_api_key_here
