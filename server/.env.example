# Django gateway (server/) — copy to .env and replace placeholders
# Never commit .env to version control.

# Required
DJANGO_SECRET_KEY=your_django_secret_key_here
backend_url=http://127.0.0.1:3030
sentiment_analyzer_url=http://127.0.0.1:5000

# Optional — JWT (defaults shown)
DJANGO_JWT_SECRET_KEY=your_jwt_signing_secret_here
DJANGO_JWT_ALGORITHM=HS256
DJANGO_JWT_ACCESS_TTL_MINUTES=30
DJANGO_JWT_REFRESH_TTL_DAYS=7

# Environment / security
DJANGO_DEBUG=true
DJANGO_ENV=local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_DB_FILENAME=db.sqlite3
DJANGO_UPSTREAM_TIMEOUT=10

# Async sentiment queue (required when publishing review events)
REDIS_URL=redis://127.0.0.1:6379/0
SENTIMENT_QUEUE_NAME=review_sentiment_queue

# Shared with Node API for internal chassis verification
INTERNAL_API_KEY=your_shared_internal_api_key_here
