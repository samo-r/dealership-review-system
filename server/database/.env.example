# Node data API (server/database/) — copy to .env and replace placeholders
# Never commit .env to version control.

# Required
PORT=3030
MONGODB_URI=mongodb://127.0.0.1:27017/your_db_name
DB_NAME=your_db_name
CORS_ORIGIN=http://localhost:3000
SEED_ON_START=true
INTERNAL_API_KEY=your_shared_internal_api_key_here
CHASSIS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Docker Compose overrides (internal service hostnames)
MONGODB_URI_DOCKER=mongodb://mongo_db:27017/your_db_name
REDIS_URL_DOCKER=redis://redis:6379/0
BACKEND_URL_DOCKER=http://api:3030
SENTIMENT_ANALYZER_URL_DOCKER=http://sentiment:5000

# Sentiment worker (also read from this file when run via Compose)
REDIS_URL=redis://127.0.0.1:6379/0
SENTIMENT_QUEUE_NAME=review_sentiment_queue
backend_url=http://127.0.0.1:3030
sentiment_analyzer_url=http://127.0.0.1:5000

# Smoke test defaults (optional)
SMOKE_TEST_HOST=localhost
SMOKE_TEST_PORT=3030
