# Node data API (server/database/) — copy to .env and replace placeholders
# Never commit .env to version control.

# Required
PORT=3030
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/
DB_NAME=autocars_ug
CORS_ORIGIN=http://localhost:3000
SEED_ON_START=false
# When true ONLY, startup clears MongoDB collections and reseeds dealerships from data/dealerships.json
INTERNAL_API_KEY=your_shared_internal_api_key_here
CHASSIS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Sentiment worker + Django queue (Upstash: use rediss:// TLS URL)
REDIS_URL=rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379/0
SENTIMENT_QUEUE_NAME=review_sentiment_queue
backend_url=http://127.0.0.1:3030
sentiment_analyzer_url=http://127.0.0.1:5000

# Smoke test defaults (optional, local dev)
SMOKE_TEST_HOST=localhost
SMOKE_TEST_PORT=3030
