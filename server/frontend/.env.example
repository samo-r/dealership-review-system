# React frontend (server/frontend/) — copy to .env for local development only.
# Never commit .env to version control.
#
# Local dev: npm start proxies /djangoapp/* to Django (see src/setupProxy.js).
# Production: the app is built into server/frontend/build/ and served by Django
# on Railway (see server/Dockerfile). No frontend env vars are needed at deploy time.

REACT_APP_DJANGO_PROXY_URL=http://127.0.0.1:8000
