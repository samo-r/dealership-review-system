# React frontend (server/frontend/) — copy to .env and adjust for your environment
# Never commit .env to version control.
#
# Dev server proxy target for /djangoapp/* requests (see src/setupProxy.js).
# Production builds use window.location.origin when the SPA and API share a host.

REACT_APP_DJANGO_PROXY_URL=http://127.0.0.1:8000
