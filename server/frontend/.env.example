# React frontend (server/frontend/) — copy to .env for local development only.
# Never commit .env to version control.
#
# Local dev: npm start proxies /djangoapp/* to Django (see src/setupProxy.js).
# Production (Vercel): API routing is configured in vercel.json — edit the
# Railway Django URL there before deploying. No frontend env vars required on Vercel.

REACT_APP_DJANGO_PROXY_URL=http://127.0.0.1:8000
